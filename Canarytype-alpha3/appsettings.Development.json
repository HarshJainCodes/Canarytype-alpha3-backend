{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "ApplicationInsights": {
      "LogLevel": {
        "Default": "Information"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "CanaryTypeDB": "YOUR_CONNECTION_STRING_HERE",
    "AzureServiceBus": "YOUR_CONNECTION_STRING_HERE"
  },
  "JWTSecret": "YOUR_JWT_SECRET_HERE",
  "Azure": {
    "SignalR": {
      "Enabled": "true"
    }
  },
  "GoogleApis": {
    "ClientId": "YOUR_CLIENT_ID",
    "ClientSecret": "YOUR_CLIENT_SECRET"
  },
  "ApplicationInsights": {
    "ConnectionString": "YOUR_APP_INSIGHTS_CONN_STRING"
  },
  "otpSenderEmail": "YOUR_EMAIL_HERE",
  "otpSenderPassword": "YOUR_EMAIL_PASSWORD"
}